COMP   = CC

#CFLAGS = -std=c++11 -fopenmp -x hip -I/opt/rocm-5.2.3/include/hip
#CFLAGS = -std=c++11 -fopenmp -x hip
CFLAGS = -std=c++11 -fopenmp -D__HIP_PLATFORM_AMD__
LFLAGS = -fopenmp
EXE = hello_jobstep-cce.x

exe : $(EXE)

$(EXE): hello_jobstep.o
	${COMP} ${LFLAGS} hello_jobstep.o -o $(EXE)

hello_jobstep.o: hello_jobstep.cpp
	${COMP} ${CFLAGS} -c hello_jobstep.cpp

.PHONY: clean

cleanall: clean
	rm -f *.out

clean:
	rm -f $(EXE) *.o select_gpu_naive.sh select_gpu_opti.sh

