#!/bin/bash -l
#
#PBS -l walltime=1:59:59
#PBS -l nodes=1:ppn=20
#PBS -N benchmark_openblas

cd $PBS_O_WORKDIR

outfile=benchmark_openblas.csv

module load foss/2015b

make mmb_gnu_obl_mc

sleep 10

echo "hostname:," `hostname`                                   >$outfile

for i in {1..11}; do
  ./mmb_gnu_obl_mc.exe 1000  | grep "CSV" | sed -e 's/CSV //' >>$outfile
  echo                                                        >>$outfile
done
for i in {1..10}; do
  ./mmb_gnu_obl_mc.exe 2500  | grep "CSV" | sed -e 's/CSV //' >>$outfile
  echo                                                        >>$outfile
done
for i in {1..5}; do
  ./mmb_gnu_obl_mc.exe 10000 | grep "CSV" | sed -e 's/CSV //' >>$outfile
  echo                                                        >>$outfile
done
for i in {1..5}; do
  ./mmb_gnu_obl_mc.exe 25000 | grep "CSV" | sed -e 's/CSV //' >>$outfile
  echo                                                        >>$outfile
done
