#!/bin/bash -l
#
#PBS -l walltime=2:59:59
#PBS -l nodes=1:ppn=16
#PBS -N benchmark_blaslibs_muk
#PBS -m bae -M kurt.lust@uantwerpen.be

#
# We've seen strange results with OpenBLAS when using all available cores on
# a node. This may be due to OS jitter. The purpose of this test is to see
# if this is an isolated problem in Antwerp or does also occur on other
# VSC clusters.

cd $PBS_O_WORKDIR

maxcores=16
sizes=(2500 2505 2510 10000 10005 10010)
# Need to do something about the next line: These PBS variables don't work on Muk...
outfile=${PBS_JOBNAME}-${PBS_JOBID}.csv

cores1=$(($maxcores-1))
cores2=$maxcores

# Put data about the cluster in the result file.
echo "hostname:,," `hostname`                                                 >$outfile
echo "jobid:,," ${PBS_JOBID}                                                 >>$outfile

#
# First test: GNU Fortran with OpenBLAS
#

# Build the executable
module load cluster/muk
module load foss/2015b
make mmb_gnu_obl_mc

# Work around a problem with GPFS on some compute nodes.
sleep 10

# First run sometimes produces strange results.
echo -e "\n\"Test run OpenBLAS, often strange results for first run\"\n"    >>$outfile
./mmb_gnu_obl_mc.exe ${sizes[0]} $maxcores | grep "CSV" | sed -e 's/CSV //' >>$outfile 

# Benchmark run
echo -e "\n\"Benchmark runs OpenBLAS\"\n"                                   >>$outfile
for size in ${sizes[@]}; do
  ./mmb_gnu_obl_mc.exe $size 1 1 1 1 1 \
                             $cores1 \
                             $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 \
                             $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 \
                             $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 \
                             $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 \
                             $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 \
                             $cores2 \
                             $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 \
                             $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 \
                             $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 \
                             $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 \
                             $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 \
                             | grep "CSV" | sed -e 's/CSV //'               >>$outfile
done


#
# Second test: Intel Fortran with MKL
#

# Build the executable
module purge
module load cluster/muk
module load intel/2015b
make mmb_intel_mc

# Work around a problem with GPFS on some compute nodes.
sleep 10

# First run sometimes produces strange results.
echo -e "\n\"Test run Intel MKL, often strange results for first run\"\n"   >>$outfile
./mmb_intel_mc.exe ${sizes[0]} $maxcores | grep "CSV" | sed -e 's/CSV //'   >>$outfile 

# Benchmark run
echo -e "\n\"Benchmark runs Intel MKL\"\n"                                  >>$outfile
for size in ${sizes[@]}; do
  ./mmb_intel_mc.exe   $size 1 1 1 1 1 \
                             $cores1 \
                             $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 \
                             $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 \
                             $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 \
                             $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 \
                             $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 $cores1 \
                             $cores2 \
                             $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 \
                             $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 \
                             $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 \
                             $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 \
                             $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 $cores2 \
                             | grep "CSV" | sed -e 's/CSV //'               >>$outfile
done




#
# Runs ended.
#
echo -e "\nCompleted"                                                       >>$outfile
